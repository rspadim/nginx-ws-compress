FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV NGINX_VERSION=release-1.31.3

# Install ALL deps in one layer (cached until Dockerfile.dev changes)
RUN apt-get update && apt-get install -y \
    build-essential git libpcre3-dev libssl-dev \
    autoconf automake libtool pkg-config \
    python3 python3-pip python3-venv \
    curl wget sudo \
    libnss3 libnspr4 libatk1.0-0t64 libatk-bridge2.0-0t64 \
    libcups2t64 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 \
    libxrandr2 libgbm1 libpango-1.0-0 libcairo2 libasound2t64 \
    libatspi2.0-0t64 \
    && rm -rf /var/lib/apt/lists/*

# Install zlib-ng (once)
RUN git clone --depth 1 --branch develop https://github.com/zlib-ng/zlib-ng.git /tmp/zlib-ng \
    && cd /tmp/zlib-ng \
    && ./configure --prefix=/usr/local --zlib-compat \
    && make -j$(nproc) \
    && make install \
    && ldconfig \
    && rm -rf /tmp/zlib-ng

# Clone nginx source (once)
RUN git clone https://github.com/nginx/nginx.git /opt/nginx-src \
    && cd /opt/nginx-src \
    && git checkout $NGINX_VERSION

WORKDIR /workspace
CMD ["bash"]
